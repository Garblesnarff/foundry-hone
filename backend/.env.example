# foundry-hone Backend Configuration

# Server port (default: 3459)
HONE_PORT=3459

# Default upscaling factor (2 or 4)
HONE_DEFAULT_SCALE=2

# Directory for downloaded ML models
HONE_MODELS_DIR=./models

# Default face restoration blend weight (0–1)
HONE_FACE_BLEND=0.8

# Enable verbose debug logging (0 or 1)
HONE_DEBUG=0
